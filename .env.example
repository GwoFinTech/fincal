# Domain & Auth
# Your public domain (used in Traefik routing labels)
DOMAIN=fincal.example.com

# ForwardAuth middleware name (Traefik label reference)
# Set to forwardauth@docker or your custom middleware
AUTH_MIDDLEWARE=forwardauth@docker

# Auth login URL - where unauthenticated users are redirected
# Leave empty to hide login button (single-user mode)
AUTH_LOGIN_URL=

# Database
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=fincal
DB_USER=postgres
DB_PASSWORD=changeme

# Watchlist Source: tsummt (direct DB) or http (remote API)
# See docs/watchlist-source.md for details
WATCHLIST_SOURCE=tsummt
# WATCHLIST_HTTP_URL=https://example.com/api/watchlist
# WATCHLIST_HTTP_FIELD=code
# TSUMMT_DB=tsummt

# Futu OpenD (optional)
# FUTU_HOST=127.0.0.1
# FUTU_PORT=11111

# Longbridge CLI (optional)
# Run longbridge auth to configure
# LONGBRIDGE_APP_KEY=
# LONGBRIDGE_APP_SECRET=
# LONGBRIDGE_ACCESS_TOKEN=

# iCal subscription base URL (must be publicly accessible)
ICAL_BASE_URL=https://fincal.example.com
